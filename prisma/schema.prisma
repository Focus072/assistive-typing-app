// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum PlanTier {
  FREE
  BASIC
  PRO
  UNLIMITED
  ADMIN
}

model User {
  id                  String       @id @default(cuid())
  email               String       @unique
  emailVerified       DateTime? // Required by NextAuth PrismaAdapter
  password            String? // Optional - Google OAuth users don't have passwords
  name                String?
  image               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime?    @updatedAt // Made optional to avoid migration issues
  planTier            PlanTier     @default(FREE)
  academicIntegrityAcceptedAt DateTime?
  stripeCustomerId    String?      @unique
  stripeSubscriptionId String?     @unique
  subscriptionStatus  String? // active, canceled, past_due, etc.
  googleTokens        GoogleToken?
  jobs                Job[]
  documents           Document[]
  chatSessions        ChatSession[]

  // NextAuth required fields
  accounts Account[]
  sessions Session[]
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  refresh_token_expires_in Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GoogleToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id                   String     @id @default(cuid())
  userId               String
  documentId           String // Google Docs document ID
  textContent          String     @db.Text
  totalChars           Int
  currentIndex         Int        @default(0)
  durationMinutes      Int
  typingProfile        String // steady, fatigue, burst, micropause, typing-test
  testWPM              Int? // WPM from typing test (for typing-test profile)
  status               String // pending, running, paused, completed, failed, stopped, expired
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  completedAt          DateTime?
  expiresAt            DateTime // TTL for cleanup
  inngestEventId       String?
  lastBatchHash        String? // Hash of last inserted batch for idempotency
  throttleDelayMs      Int        @default(500) // Adaptive throttling delay
  docInsertIndex       Int?       // Cached Google Docs end-of-document index; eliminates per-batch documents.get calls
  errorCode            String? // Specific error codes (GOOGLE_AUTH_REVOKED, etc.)
  scheduledAt          DateTime? // When the job is scheduled to start (null = immediate)
  engineState          String?    @db.Text // JSON-serialized EngineState (PRNG + profile phase state) persisted between batches
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  events               JobEvent[]
  documentAsCurrentJob Document?  @relation("DocumentCurrentJob")

  @@index([userId, status])
  @@index([status, createdAt])
}

model JobEvent {
  id        String   @id @default(cuid())
  jobId     String
  type      String // started, batch_success, paused, resumed, failed, stopped, throttled, etc.
  details   String?  @db.Text // JSON or text details
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([createdAt])
}

model Document {
  id           String   @id @default(cuid())
  userId       String
  documentId   String // Google Docs document ID
  state        String // idle, running
  currentJobId String?  @unique // Reference to active Job (nullable, unique)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentJob   Job?     @relation("DocumentCurrentJob", fields: [currentJobId], references: [id], onDelete: SetNull)

  @@unique([userId, documentId])
  @@index([userId, state])
  @@index([documentId])
}

model Setting {
  id    String  @id @default(cuid())
  key   String  @unique
  value String? @db.Text
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("New Chat")
  pinned    Boolean       @default(false)
  folder    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId, createdAt])
  @@index([userId, pinned])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String      @db.Text
  order     Int
  feedback  String?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, order])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String    @db.Text
  badge       String    @default("Update")
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
